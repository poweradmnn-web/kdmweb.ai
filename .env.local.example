# ── Email delivery (Resend) ───────────────────────────────────────────────
# Copy this file to ".env.local" and fill in the values.
# .env.local is gitignored — never commit real keys.

# Your Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Where leads are delivered (your inbox)
CONTACT_TO_EMAIL=

# Verified sender address. Must be on a domain you've verified in Resend,
# e.g. hello@kdmweb.ai. For quick testing you can use: onboarding@resend.dev
CONTACT_FROM_EMAIL=

# ── Booking ────────────────────────────────────────────────────────────────
# Your scheduling link. In Next.js a browser-readable var MUST be prefixed
# NEXT_PUBLIC_. Set this in Vercel for production (and here for local dev).
#   Cal.com  → https://cal.com/your-name/intro
#   Calendly → https://calendly.com/your-name/intro
NEXT_PUBLIC_BOOKING_URL=

# Optional — "calcom" (default) or "calendly".
NEXT_PUBLIC_BOOKING_PROVIDER=
